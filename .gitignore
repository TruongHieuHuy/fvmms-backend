# ============================================
# FVMMS Backend - Node.js + TypeScript + Prisma
# Multi-repo setup (backend standalone)
# ============================================

# === Dependencies ===
node_modules/
package-lock.json  # hoặc comment dòng này nếu muốn commit lock file

# === Build Output (from tsconfig) ===
dist/
*.tsbuildinfo
*.js.map

# === Environment Variables & Secrets ===
.env
.env.*
!.env.example
!.env.sample
*.env.backup
*_backup.env
.env.backup.*

# Config with credentials
config/local.json
config/production.json
config/*.local.json

# === Database ===
# Local PostgreSQL data (if running via Docker Compose)
pgdata/
postgres-data/
pg_log/
pg_wal/

# Database dumps & backups
*.sql
*.sql.backup
*.dump
*.bak
*.pgpass

# SQLite (for local testing if used)
*.sqlite
*.sqlite3
*.db
prisma/*.db

# === Prisma ORM ===
# Generated client (rebuild with `npx prisma generate`)
# Uncomment if you want to commit generated client:
# !node_modules/.prisma/
node_modules/.prisma/
generated/

# Migration previews
prisma/migrations/*_preview/
prisma/*.db-journal

# === Logs (Winston output) ===
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
combined.log
error.log
access.log
app.log

# === Testing & Coverage ===
coverage/
.nyc_output/
junit.xml
test-results/

# === Cache & Temp ===
.eslintcache
.cache/
.npm/
*.tmp
*.temp
*.swp
.sessions/

# === Docker ===
docker-compose.override.yml
volumes/

