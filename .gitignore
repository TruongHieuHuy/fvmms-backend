.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.vscode/*.code-workspace

# IntelliJ / WebStorm
.idea/
*.iml
*.iws
*.ipr

# === OS Generated ===
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

